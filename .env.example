# LLM Provider API Key (required for AI-powered generation)
# Get yours at: https://platform.openai.com/api-keys
# Example: sk-proj-abc123def456...
OPENAI_API_KEY=sk-

# Optional: use a different LLM model (default: gpt-4o)
# FOST_LLM_MODEL=gpt-4-turbo
# FOST_LLM_MODEL=gpt-3.5-turbo

# Optional: disable LLM for deterministic-only generation (no AI features)
# Set to 'false' to skip API calls and generate from spec alone
# FOST_AI_ENABLED=true

# Optional: log level for debugging
# FOST_LOG_LEVEL=debug
# FOST_LOG_LEVEL=info
