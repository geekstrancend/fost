{
  "name": "fost",
  "version": "0.1.0",
  "description": "AI-powered SDK generator for Web2 and Web3 APIs. Generate fully-typed, documented TypeScript SDKs in minutes from OpenAPI or smart contract ABIs.",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "bin": {
    "fost": "./bin/fost.js"
  },
  "files": [
    "dist/",
    "bin/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "sdk",
    "generator",
    "ai",
    "openapi",
    "graphql",
    "web3",
    "smart-contracts",
    "typescript",
    "cli",
    "code-generation"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/geekstrancend/fost.git"
  },
  "homepage": "https://github.com/geekstrancend/fost#readme",
  "bugs": {
    "url": "https://github.com/geekstrancend/fost/issues"
  },
  "author": "Emmyhack",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./cli": {
      "types": "./dist/src/cli/index.d.ts",
      "default": "./dist/src/cli/index.js"
    },
    "./errors": {
      "types": "./dist/src/errors/index.d.ts",
      "default": "./dist/src/errors/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "vitest run --coverage",
    "test:unit": "vitest run --coverage",
    "test:e2e": "vitest run tests/e2e",
    "test:watch": "vitest watch",
    "lint": "eslint src",
    "lint:format": "prettier --check .",
    "cli": "node dist/src/cli/index.js",
    "prepublishOnly": "npm run build && npm run test",
    "batch:generate": "ts-node scripts/batch-generate.ts",
    "publish:sdk": "ts-node scripts/publish-sdk.ts",
    "ci:local": "npm run build && npm run batch:generate -- --specs-dir ./api-specs --output ./generated-sdks --languages typescript,python",
    "ci:validate": "npm run lint && npm run test && npm run batch:generate -- --no-validate"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitest/coverage-v8": "^2.0.5",
    "eslint": "^9.9.0",
    "typescript": "^5.5.4",
    "vite-tsconfig-paths": "^4.3.2",
    "vitest": "^2.0.5"
  },
  "dependencies": {
    "js-yaml": "^4.1.1"
  }
}
